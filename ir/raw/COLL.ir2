fn GroundBump {
  x = *CharBlockY@0x0045        ; COLL.S:714
  a = *CharSword@0x004e        ; COLL.S:716
  cmp a, #0x02              ; COLL.S:717
  if a == #0x02 goto :skipair  ; COLL.S:718
  a = *(FloorY+1@0x127f + x)   ; COLL.S:720
  c = 1                            ; COLL.S:721
  a = a - *CharY@0x0042 - (1 - c) ; COLL.S:722
  cmp a, #0x0f              ; COLL.S:723
  if a >= #0x0f goto AirBump  ; COLL.S:724
:skipair:
  a = *(FloorY+1@0x127f + x)   ; COLL.S:726
  *CharY@0x0042 = a            ; COLL.S:727
  a = *CharYVel@0x0048        ; COLL.S:729
  cmp a, #OofVelocity              ; COLL.S:730
  if a < #OofVelocity goto :okvel  ; COLL.S:731
  a = #0xfb                  ; COLL.S:732
  call addcharx                  ; COLL.S:733
  *CharX@0x0041 = a            ; COLL.S:734
  return                           ; COLL.S:735
:okvel:
  a = #0x00                  ; COLL.S:737
  *CharYVel@0x0048 = a            ; COLL.S:738
  a = *CharLife@0x004f        ; COLL.S:740
  if a == #0x00 goto :deadbump  ; COLL.S:741
  a = *CharSword@0x004e        ; COLL.S:745
  cmp a, #0x02              ; COLL.S:746
  if a == #0x02 goto :CollideEng  ; COLL.S:747
:normal:
  x = *CharPosn@0x0040        ; COLL.S:752
  cmp x, #0x18              ; COLL.S:754
  if x == #0x18 goto :hard  ; COLL.S:755
  cmp x, #0x19              ; COLL.S:756
  if x == #0x19 goto :hard  ; COLL.S:757
  cmp x, #0x28              ; COLL.S:759
  if x < #0x28 goto :1  ; COLL.S:760
  cmp x, #0x2b              ; COLL.S:761
  if x < #0x2b goto :hard  ; COLL.S:762
:1:
