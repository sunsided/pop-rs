  x = #0x09                  ; COLL.S:313
:zloop:
:smodSN:
  a = *(SNbelow@0x0380 + x)   ; COLL.S:315
  *(SNlastframe@0x0370 + x) = a   ; COLL.S:316
:smodCD:
  a = *(CDbelow@0x0340 + x)   ; COLL.S:318
