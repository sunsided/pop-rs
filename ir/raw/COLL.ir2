fn CHECKCOLL {
  if a == #flask goto :no  ; COLL.S:529
  if a == #gate goto :gate  ; COLL.S:532
  if a == #slicer goto :slicer  ; COLL.S:535
  cmp a, #mirror              ; COLL.S:537
  if a == #mirror goto :mirror  ; COLL.S:538
  if ne goto :c1       ; COLL.S:539
:mirror:
  a = *CharID@0x004d        ; COLL.S:545
  if a != #0x00 goto :c1  ; COLL.S:546
  a = *CharPosn@0x0040        ; COLL.S:547
  if a < #0x27 goto :c1  ; COLL.S:549
  if a >= #0x2c goto :c1  ; COLL.S:551
  a = *CharFace@0x0043        ; COLL.S:552
  if a >=0 goto :c1  ; COLL.S:553
  call smashmirror                  ; COLL.S:555
  a = #0xff                  ; COLL.S:556
  *createshad@0x00e5 = a            ; COLL.S:557
  c = 0                            ; COLL.S:559
  return                           ; COLL.S:560
:slicer:
  a = *(BlueSpec@0x0026)[y]   ; COLL.S:564
  cmp a, #slicerExt              ; COLL.S:565
  if a != #slicerExt goto :no  ; COLL.S:566
  if eq goto :c1       ; COLL.S:567
:gate:
  call gatebarr?                  ; COLL.S:571
  if cc goto :c1       ; COLL.S:572
:no:
  c = 0                            ; COLL.S:576
  return                           ; COLL.S:577
:c1:
  a = *tempblockx@0x0091        ; COLL.S:582
  call getblockej                  ; COLL.S:583
  call AdjustScrn                  ; COLL.S:584
  c = 0                            ; COLL.S:585
  a = a + #angle + c              ; COLL.S:586
  *blockedge@0x00c2 = a            ; COLL.S:587
:yes:
  c = 1                            ; COLL.S:588
]rts:
  return                           ; COLL.S:589
}

fn AdjustScrn {
  x = *tempscrn@0x0093        ; COLL.S:603
  if x == *VisScrn@0x00cb goto ]rts  ; COLL.S:605
  if x == *scrnLeft@0x0031 goto :osL  ; COLL.S:607
  if x == *scrnBelowL@0x0035 goto :osL  ; COLL.S:609
  if x == *scrnRight@0x0032 goto :osR  ; COLL.S:611
  if x == *scrnBelowR@0x0038 goto :osR  ; COLL.S:613
  return                           ; COLL.S:614
:osR:
  c = 0                            ; COLL.S:615
  a = a + #ScrnWidth + c              ; COLL.S:616
  return                           ; COLL.S:617
:osL:
  c = 1                            ; COLL.S:618
  a = a - #ScrnWidth - (1 - c)        ; COLL.S:619
]rts:
  return                           ; COLL.S:620
}

fn collide {
  *CollFace@0x00f1 = x            ; COLL.S:632
  x = *CharLife@0x004f        ; COLL.S:634
  if x >=0 goto ]rts  ; COLL.S:635
  x = *CharPosn@0x0040        ; COLL.S:637
  if x == #0xb1 goto ]rts  ; COLL.S:639
  c = 0                            ; COLL.S:641
  a = a + *CharX@0x0041 + c    ; COLL.S:642
  *CharX@0x0041 = a            ; COLL.S:643
  call rdblock1                  ; COLL.S:647
  x = *CollFace@0x00f1        ; COLL.S:649
  if x >=0 goto :faceL  ; COLL.S:650
  cmp a, #block              ; COLL.S:652
  if a == #block goto :2  ; COLL.S:653
  if ne goto :1       ; COLL.S:654
:2:
  *tempblockx@0x0091 -= 1                         ; COLL.S:656
  goto :3                ; COLL.S:657
:faceL:
  if a == #panelwof goto :4  ; COLL.S:660
  if a == #panelwif goto :4  ; COLL.S:662
  if a != #block goto :1  ; COLL.S:664
:4:
  *tempblockx@0x0091 += 1                         ; COLL.S:666
  a = *tempscrn@0x0093        ; COLL.S:667
  if a != #0x00 goto :3  ; COLL.S:668
  a = *tempblockx@0x0091        ; COLL.S:669
  if a != #0x0a goto :3  ; COLL.S:671
  a = *CharScrn@0x004b        ; COLL.S:672
  *tempscrn@0x0093 = a            ; COLL.S:673
  a = #0x00                  ; COLL.S:674
  *tempblockx@0x0091 = a            ; COLL.S:675
:3:
  call rdblock1                  ; COLL.S:677
:1:
  call cmpspace                  ; COLL.S:679
  if ne goto GroundBump       ; COLL.S:680
AirBump:
  a = #0xfc                  ; COLL.S:686
  call addcharx                  ; COLL.S:687
  *CharX@0x0041 = a            ; COLL.S:688
  a = *CharAction@0x0046        ; COLL.S:690
  if a != #0x04 goto :3  ; COLL.S:692
  a = #0x00                  ; COLL.S:694
  *CharXVel@0x0047 = a            ; COLL.S:695
  if eq goto :smackwall       ; COLL.S:696
:3:
  a = #bumpfall                  ; COLL.S:698
  call jumpseq                  ; COLL.S:699
  call animchar                  ; COLL.S:700
:smackwall:
BumpSound:
  a = #0x01                  ; COLL.S:705
  *alertguard@0x00e4 = a            ; COLL.S:706
  a = #SmackWall                  ; COLL.S:707
  tail_call addsound                ; COLL.S:708
]rts:
  return                           ; COLL.S:620
}

fn AirBump {
