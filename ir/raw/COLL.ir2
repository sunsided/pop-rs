fn checkcoll1 {
  *tempblockx@0x0091 = x            ; COLL.S:496
  a = *CharBlockY@0x0045        ; COLL.S:498
  if a >=0 goto :2  ; COLL.S:499
  c = 0                            ; COLL.S:500
