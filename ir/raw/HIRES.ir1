  a = #0x02                  ; HIRES.S:1981
]setfast:
  ??? sta ]ramrd1+1            ; HIRES.S:1983
  ??? sta ]ramrd2+1            ; HIRES.S:1984
  ??? sta ]ramrd3+1            ; HIRES.S:1985
  ??? sta ]ramrd4+1            ; HIRES.S:1986
  ??? sta ]ramrd5+1            ; HIRES.S:1987
  return                           ; HIRES.S:1988
}

fn SETFASTAUX {
  a = #0x03                  ; HIRES.S:1991
  if ne goto ]setfast       ; HIRES.S:1992
FASTBLACK:
  a = *color@0x0006        ; HIRES.S:2006
  ??? sta :smCOLOR+1            ; HIRES.S:2007
  a = *PAGE@0x0000        ; HIRES.S:2009
  ??? sta :smPAGE+1            ; HIRES.S:2010
  a = *XCO@0x0001        ; HIRES.S:2012
  ??? sta :smXCO+1            ; HIRES.S:2013
  a = *width@0x0005        ; HIRES.S:2015
  c = 1                            ; HIRES.S:2016
  a = a - #0x01 - (1 - c)        ; HIRES.S:2017
  ??? sta :smSTART+1            ; HIRES.S:2018
  a = *YCO@0x0002        ; HIRES.S:2020
  x = a                            ; HIRES.S:2021
  a = a - *height@0x0004 - (1 - c) ; HIRES.S:2022
  ??? sta :smTOP+1            ; HIRES.S:2023
:outloop:
  a = *(YLO@0xe000 + x)   ; HIRES.S:2026
  c = 0                            ; HIRES.S:2027
:smXCO:
  a = a + #0x00 + c              ; HIRES.S:2028
  ??? sta :smod+1            ; HIRES.S:2029
  a = *(YHI@0xe0c0 + x)   ; HIRES.S:2031
:smPAGE:
  a = a + #0x20 + c              ; HIRES.S:2032
  ??? sta :smod+2            ; HIRES.S:2033
:smCOLOR:
  a = #0x80                  ; HIRES.S:2035
:smSTART:
  y = #0x03                  ; HIRES.S:2037
:inloop:
:smod:
  *($2000@0x2000 + y) = a   ; HIRES.S:2040
  y -= 1                         ; HIRES.S:2041
  if pl goto :inloop       ; HIRES.S:2042
  x -= 1                         ; HIRES.S:2044
:smTOP:
  cmp x, #0xff              ; HIRES.S:2045
  if ne goto :outloop       ; HIRES.S:2046
  return                           ; HIRES.S:2048
}

