fn COPYSCRN {
  a = *IMAGE+1@0x0005        ; HIRES.S:2061
  ??? sta :dst1+2            ; HIRES.S:2062
  c = 0                            ; HIRES.S:2063
  a = a + #0x10 + c              ; HIRES.S:2064
  ??? sta :dst2+2            ; HIRES.S:2065
  a = *IMAGE@0x0004        ; HIRES.S:2067
  ??? sta :org1+2            ; HIRES.S:2068
  a = a + #0x10 + c              ; HIRES.S:2069
  ??? sta :org2+2            ; HIRES.S:2070
  x = #0x10                  ; HIRES.S:2072
  y = #0x00                  ; HIRES.S:2074
:loop:
:org1:
  a = *($2000@0x2000 + y)   ; HIRES.S:2076
:dst1:
  *($4000@0x4000 + y) = a   ; HIRES.S:2077
:org2:
  a = *($3000@0x3000 + y)   ; HIRES.S:2079
:dst2:
  *($5000@0x5000 + y) = a   ; HIRES.S:2080
  y += 1                         ; HIRES.S:2082
  if ne goto :loop       ; HIRES.S:2083
  ??? inc :org1+2            ; HIRES.S:2085
  ??? inc :org2+2            ; HIRES.S:2086
  ??? inc :dst1+2            ; HIRES.S:2087
  ??? inc :dst2+2            ; HIRES.S:2088
  x -= 1                         ; HIRES.S:2090
  if ne goto :loop       ; HIRES.S:2091
  return                           ; HIRES.S:2093
}

fn INVERTY {
  x = #0xbf                  ; HIRES.S:2099
  y = #0x00                  ; HIRES.S:2100
:loop:
  a = *(YLO@0xe000 + x)   ; HIRES.S:2104
  ??? pha             ; HIRES.S:2105
  a = *(YLO@0xe000 + y)   ; HIRES.S:2106
  *(YLO@0xe000 + x) = a   ; HIRES.S:2107
  ??? pla             ; HIRES.S:2108
  *(YLO@0xe000 + y) = a   ; HIRES.S:2109
  a = *(YHI@0xe0c0 + x)   ; HIRES.S:2111
  ??? pha             ; HIRES.S:2112
  a = *(YHI@0xe0c0 + y)   ; HIRES.S:2113
  *(YHI@0xe0c0 + x) = a   ; HIRES.S:2114
  ??? pla             ; HIRES.S:2115
  *(YHI@0xe0c0 + y) = a   ; HIRES.S:2116
  x -= 1                         ; HIRES.S:2120
  y += 1                         ; HIRES.S:2121
  cmp y, #0x60              ; HIRES.S:2122
  if cc goto :loop       ; HIRES.S:2123
]rts:
  return                           ; HIRES.S:2124
  ??? usr $a9,1,$0000,*-org            ; HIRES.S:2129
}
