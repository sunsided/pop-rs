fn PlaySongI {
  call setaux                  ; MASTER.S:1390
  if eq goto ]rts       ; MASTER.S:1391
  y = a                            ; MASTER.S:1393
  a = *musicon@0x031a        ; MASTER.S:1394
  a = a & *soundon@0x0203              ; MASTER.S:1395
  if eq goto :pause       ; MASTER.S:1396
