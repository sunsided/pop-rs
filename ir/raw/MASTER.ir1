  if ne goto :loop       ; MASTER.S:1403
]rts:
  return                           ; MASTER.S:1404
:pause:
  a = x                            ; MASTER.S:1406
tpause:
:loop:
  *pausetemp@0x03f7 = a            ; MASTER.S:1413
  y = #0x02                  ; MASTER.S:1415
:loop1:
  x = #0x00                  ; MASTER.S:1416
:loop2:
  call StartGame?                  ; MASTER.S:1417
  x -= 1                         ; MASTER.S:1418
  if ne goto :loop2       ; MASTER.S:1419
  y -= 1                         ; MASTER.S:1420
  if ne goto :loop1       ; MASTER.S:1421
  a = *pausetemp@0x03f7        ; MASTER.S:1423
  c = 1                            ; MASTER.S:1424
  a = a - #0x01 - (1 - c)        ; MASTER.S:1425
  if ne goto :loop       ; MASTER.S:1426
]rts:
  return                           ; MASTER.S:1427
}

fn tpause  (aka :loop) {
  *pausetemp@0x03f7 = a            ; MASTER.S:1413
  y = #0x02                  ; MASTER.S:1415
:loop1:
  x = #0x00                  ; MASTER.S:1416
:loop2:
  call StartGame?                  ; MASTER.S:1417
  x -= 1                         ; MASTER.S:1418
  if ne goto :loop2       ; MASTER.S:1419
  y -= 1                         ; MASTER.S:1420
  if ne goto :loop1       ; MASTER.S:1421
  a = *pausetemp@0x03f7        ; MASTER.S:1423
  c = 1                            ; MASTER.S:1424
  a = a - #0x01 - (1 - c)        ; MASTER.S:1425
  if ne goto :loop       ; MASTER.S:1426
]rts:
  return                           ; MASTER.S:1427
:loop:
  call StartGame?                  ; MASTER.S:1400
  call xmplay                  ; MASTER.S:1401
  cmp a, #0x00              ; MASTER.S:1402
  if ne goto :loop       ; MASTER.S:1403
  goto ]rts                ; MASTER.S:1404
}

