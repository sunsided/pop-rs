        pc = 1                          ; CTRL.S:316
      }
    }
    state 1 => {
      call getunderft                ; CTRL.S:318
      cmp a, #block              ; CTRL.S:319
      if a != #block {    ; CTRL.S:320
        pc = 21                          ; CTRL.S:320
      } else {
        pc = 2                          ; CTRL.S:320
      }
    }
    state 2 => {
      call InsideBlock                ; CTRL.S:321
      pc = 21                          ; CTRL.S:322
    }
    state 3 => {
      call cmpspace                ; CTRL.S:323
      if ne {                ; CTRL.S:324
        pc = 27                          ; CTRL.S:324
