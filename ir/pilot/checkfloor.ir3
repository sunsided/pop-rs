      } else {
        pc = 21                          ; CTRL.S:384
      }
    }
    state 21 => {
      pc = 22                          ; CTRL.S:387
    }
    state 22 => {
      a = #stepfall                  ; CTRL.S:387
      if a != #0x00 {    ; CTRL.S:388
        pc = 33                          ; CTRL.S:388
      } else {
        pc = 23                          ; CTRL.S:388
      }
    }
    state 23 => {
      a = #stepfall2                  ; CTRL.S:390
      if a != #0x00 {    ; CTRL.S:391
        pc = 33                          ; CTRL.S:391
      } else {
        pc = 24                          ; CTRL.S:391
