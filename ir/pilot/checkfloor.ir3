; module CTRL from 01 POP Source/Source/CTRL.S

fn CHECKFLOOR {
  a = *CharAction@0x0046        ; CTRL.S:107
  if a == #0x06 {    ; CTRL.S:109
    return                           ; CTRL.S:99
  }
  if a != #0x05 {    ; CTRL.S:112
    if a == #0x04 {    ; CTRL.S:121
      tail_call falling           ; CTRL.S:121
    }
    if a != #0x03 {    ; CTRL.S:123
      if a == #0x02 {    ; CTRL.S:132
        return                           ; CTRL.S:99
      }
      tail_call onground           ; CTRL.S:133
    }
    a = *CharPosn@0x0040        ; CTRL.S:124
    if a < #0x66 {    ; CTRL.S:126
      return                           ; CTRL.S:99
    }
    if a >= #0x6a {    ; CTRL.S:128
      return                           ; CTRL.S:99
    }
    tail_call fallon           ; CTRL.S:129
  }
  a = *CharPosn@0x0040        ; CTRL.S:113
  if a == #0x6d {    ; CTRL.S:115
    tail_call onground           ; CTRL.S:118
  }
  if a != #0xb9 {    ; CTRL.S:117
    return                           ; CTRL.S:99
  }
  tail_call onground           ; CTRL.S:118
}

fn onground {
  dispatch pc = 0 {    ; CTRL.S:316
