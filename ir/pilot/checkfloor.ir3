        pc = 33                          ; CTRL.S:397
      } else {
        pc = 26                          ; CTRL.S:397
      }
    }
    state 26 => {
      a = #0x05                  ; CTRL.S:400
      call addcharx                ; CTRL.S:401
      *CharX@0x0041 = a            ; CTRL.S:402
      call rereadblocks                ; CTRL.S:403
      pc = 23                          ; CTRL.S:404
    }
    state 27 => {
      return                           ; CTRL.S:405
    }
    state 28 => {
      a = *CharID@0x004d        ; CTRL.S:407
      cmp a, #0x02              ; CTRL.S:408
      if a < #0x02 {    ; CTRL.S:409
        pc = 32                          ; CTRL.S:409
      } else {
        pc = 29                          ; CTRL.S:409
      }
    }
    state 29 => {
      a = *CharXVel@0x0047        ; CTRL.S:410
      if a <0 {    ; CTRL.S:411
        pc = 31                          ; CTRL.S:411
      } else {
        pc = 30                          ; CTRL.S:411
      }
    }
    state 30 => {
      a = #0x00                  ; CTRL.S:412
      *droppedout@0x00e7 = a            ; CTRL.S:413
      a = #efightfallfwd                  ; CTRL.S:414
      if a != #0x00 {    ; CTRL.S:415
        pc = 33                          ; CTRL.S:415
      } else {
        pc = 31                          ; CTRL.S:415
      }
    }
    state 31 => {
      a = #efightfall                  ; CTRL.S:416
      if a != #0x00 {    ; CTRL.S:417
        pc = 33                          ; CTRL.S:417
      } else {
        pc = 32                          ; CTRL.S:417
      }
    }
    state 32 => {
      a = #0x01                  ; CTRL.S:418
      *droppedout@0x00e7 = a            ; CTRL.S:419
      a = #fightfall                  ; CTRL.S:420
      if a != #0x00 {    ; CTRL.S:421
        pc = 33                          ; CTRL.S:421
      } else {
        pc = 33                          ; CTRL.S:421
      }
    }
    state 33 => {
      call jumpseq                ; CTRL.S:424
      call animchar                ; CTRL.S:425
      call rereadblocks                ; CTRL.S:427
      call getunderft                ; CTRL.S:428
      call cmpwall                ; CTRL.S:429
      if eq {                ; CTRL.S:430
        pc = 36                          ; CTRL.S:430
