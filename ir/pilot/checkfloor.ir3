        pc = 6                          ; CTRL.S:332
      }
    }
    state 6 => {
      a = *CharBlockY@0x0045        ; CTRL.S:333
      if a != #0x00 {    ; CTRL.S:334
        pc = 12                          ; CTRL.S:334
      } else {
        pc = 7                          ; CTRL.S:334
      }
    }
    state 7 => {
      a = *CharScrn@0x004b        ; CTRL.S:335
      cmp a, #0x02              ; CTRL.S:336
      if a == #0x02 {    ; CTRL.S:337
        pc = 10                          ; CTRL.S:337
      } else {
        pc = 8                          ; CTRL.S:337
      }
    }
    state 8 => {
      cmp a, #0x0d              ; CTRL.S:338
      if a != #0x0d {    ; CTRL.S:339
        pc = 12                          ; CTRL.S:339
      } else {
        pc = 9                          ; CTRL.S:339
      }
    }
    state 9 => {
      a = *tempblockx@0x0091        ; CTRL.S:340
      cmp a, #0x06              ; CTRL.S:341
      if a < #0x06 {    ; CTRL.S:342
        pc = 12                          ; CTRL.S:342
      } else {
        pc = 10                          ; CTRL.S:342
      }
    }
    state 10 => {
      a = #floor                  ; CTRL.S:344
      *(BlueType@0x0024)[y] = a   ; CTRL.S:345
      call indexblock                ; CTRL.S:346
      a = #0x02                  ; CTRL.S:347
      call :sub                ; CTRL.S:348
      y += 1                         ; CTRL.S:349
      pc = 11                          ; CTRL.S:350
    }
    state 11 => {
      call markwipe                ; CTRL.S:350
      tail_call markred           ; CTRL.S:351
    }
    state 12 => {
      pc = 13                          ; CTRL.S:356
    }
    state 13 => {
      a = #0x00                  ; CTRL.S:357
      *rjumpflag@0x023a = a            ; CTRL.S:358
      *CharSword@0x004e = a            ; CTRL.S:359
      *CharBlockY@0x0045 += 1                         ; CTRL.S:361
      call addslicers                ; CTRL.S:362
      a = *CharPosn@0x0040        ; CTRL.S:364
      *rjumpflag@0x023a = a            ; CTRL.S:367
      cmp a, #0x09              ; CTRL.S:369
      if a == #0x09 {    ; CTRL.S:370
        pc = 22                          ; CTRL.S:370
      } else {
        pc = 14                          ; CTRL.S:370
      }
    }
    state 14 => {
      cmp a, #0x0d              ; CTRL.S:371
      if a == #0x0d {    ; CTRL.S:372
        pc = 23                          ; CTRL.S:372
      } else {
        pc = 15                          ; CTRL.S:372
      }
    }
    state 15 => {
      cmp a, #0x1a              ; CTRL.S:373
      if a == #0x1a {    ; CTRL.S:374
        pc = 24                          ; CTRL.S:374
      } else {
        pc = 16                          ; CTRL.S:374
      }
    }
    state 16 => {
      cmp a, #0x2c              ; CTRL.S:375
      if a == #0x2c {    ; CTRL.S:376
        pc = 25                          ; CTRL.S:376
      } else {
        pc = 17                          ; CTRL.S:376
      }
    }
    state 17 => {
      cmp a, #0x51              ; CTRL.S:377
      if a < #0x51 {    ; CTRL.S:378
        pc = 19                          ; CTRL.S:378
      } else {
        pc = 18                          ; CTRL.S:378
      }
    }
    state 18 => {
      cmp a, #0x56              ; CTRL.S:379
      if a < #0x56 {    ; CTRL.S:380
        pc = 26                          ; CTRL.S:380
      } else {
        pc = 19                          ; CTRL.S:380
      }
    }
    state 19 => {
      cmp a, #0x96              ; CTRL.S:381
      if a < #0x96 {    ; CTRL.S:382
        pc = 21                          ; CTRL.S:382
      } else {
        pc = 20                          ; CTRL.S:382
      }
    }
    state 20 => {
      cmp a, #0xb4              ; CTRL.S:383
      if a < #0xb4 {    ; CTRL.S:384
