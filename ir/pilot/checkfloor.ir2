  if a == #0x02 goto :yes  ; CTRL.S:337
  cmp a, #0x0d              ; CTRL.S:338
  if a != #0x0d goto :no  ; CTRL.S:339
  a = *tempblockx@0x0091        ; CTRL.S:340
  cmp a, #0x06              ; CTRL.S:341
  if a < #0x06 goto :no  ; CTRL.S:342
:yes:
  a = #0x01                  ; CTRL.S:344
  ??? sta (BlueType),y            ; CTRL.S:345
  call indexblock                  ; CTRL.S:346
  a = #0x02                  ; CTRL.S:347
  call :sub                  ; CTRL.S:348
  ??? iny             ; CTRL.S:349
:sub:
  call markwipe                  ; CTRL.S:350
  tail_call markred                ; CTRL.S:351
:no:
startfall:
  a = #0x00                  ; CTRL.S:357
  *rjumpflag@0x023a = a            ; CTRL.S:358
  *CharSword@0x004e = a            ; CTRL.S:359
  ??? inc CharBlockY            ; CTRL.S:361
  call addslicers                  ; CTRL.S:362
  a = *CharPosn@0x0040        ; CTRL.S:364
  *rjumpflag@0x023a = a            ; CTRL.S:367
  cmp a, #0x09              ; CTRL.S:369
  if a == #0x09 goto :stepfall  ; CTRL.S:370
  cmp a, #0x0d              ; CTRL.S:371
  if a == #0x0d goto :stepfall2  ; CTRL.S:372
  cmp a, #0x1a              ; CTRL.S:373
  if a == #0x1a goto :jumpfall  ; CTRL.S:374
  cmp a, #0x2c              ; CTRL.S:375
  if a == #0x2c goto :rjumpfall  ; CTRL.S:376
  cmp a, #0x51              ; CTRL.S:377
  if a < #0x51 goto :2  ; CTRL.S:378
  cmp a, #0x56              ; CTRL.S:379
  if a < #0x56 goto :hdropfall  ; CTRL.S:380
:2:
  cmp a, #0x96              ; CTRL.S:381
  if a < #0x96 goto :1  ; CTRL.S:382
  cmp a, #0xb4              ; CTRL.S:383
  if a < #0xb4 goto :fightfall  ; CTRL.S:384
:1:
:stepfall:
  a = #0x07                  ; CTRL.S:387
  if a != #0x00 goto :doit  ; CTRL.S:388
:stepfall2:
  a = #0x13                  ; CTRL.S:390
  if a != #0x00 goto :doit  ; CTRL.S:391
:jumpfall:
  a = #0x12                  ; CTRL.S:393
  if a != #0x00 goto :doit  ; CTRL.S:394
:rjumpfall:
  a = #0x15                  ; CTRL.S:396
  if a != #0x00 goto :doit  ; CTRL.S:397
:hdropfall:
  a = #0x05                  ; CTRL.S:400
  call addcharx                  ; CTRL.S:401
  *CharX@0x0041 = a            ; CTRL.S:402
  call rereadblocks                  ; CTRL.S:403
  goto :stepfall2                ; CTRL.S:404
]rts:
  return                           ; CTRL.S:405
:fightfall:
  a = *CharID@0x004d        ; CTRL.S:407
  cmp a, #0x02              ; CTRL.S:408
  if a < #0x02 goto :player  ; CTRL.S:409
  a = *CharXVel@0x0047        ; CTRL.S:410
  if a <0 goto :fb  ; CTRL.S:411
  a = #0x00                  ; CTRL.S:412
  *droppedout@0x00e7 = a            ; CTRL.S:413
  a = #0x53                  ; CTRL.S:414
  if a != #0x00 goto :doit  ; CTRL.S:415
:fb:
  a = #0x52                  ; CTRL.S:416
  if a != #0x00 goto :doit  ; CTRL.S:417
:player:
  a = #0x01                  ; CTRL.S:418
  *droppedout@0x00e7 = a            ; CTRL.S:419
  a = #0x51                  ; CTRL.S:420
  if a != #0x00 goto :doit  ; CTRL.S:421
:doit:
  call jumpseq                  ; CTRL.S:424
  call animchar                  ; CTRL.S:425
  call rereadblocks                  ; CTRL.S:427
  call getunderft                  ; CTRL.S:428
  call cmpwall                  ; CTRL.S:429
  if eq goto :bump       ; CTRL.S:430
  call getinfront                  ; CTRL.S:431
  call cmpwall                  ; CTRL.S:432
  if ne goto ]rts       ; CTRL.S:433
  tail_call CDpatch                ; CTRL.S:434
:bump:
  tail_call InsideBlock                ; CTRL.S:436
}

fn fallon {
  a = *btn@0x003d        ; CTRL.S:249
  ??? and CharLife            ; CTRL.S:250
  if pl goto ]rts       ; CTRL.S:251
  a = *CharYVel@0x0048        ; CTRL.S:253
  if a >= #0x20 goto ]rts  ; CTRL.S:255
  a = *CharY@0x0042        ; CTRL.S:257
  c = 0                            ; CTRL.S:258
  a = a + #0x19 + c              ; CTRL.S:259
  x = *CharBlockY@0x0045        ; CTRL.S:260
  ??? inx             ; CTRL.S:261
  ??? cmp FloorY,x            ; CTRL.S:262
  if cc goto ]rts       ; CTRL.S:263
  a = *CharX@0x0041        ; CTRL.S:268
  *savekidx@0x00af = a            ; CTRL.S:269
  a = #0xf8                  ; CTRL.S:270
  call addcharx                  ; CTRL.S:271
  *CharX@0x0041 = a            ; CTRL.S:272
  call rereadblocks                  ; CTRL.S:273
  call :test                  ; CTRL.S:275
  if ne goto :ok       ; CTRL.S:276
  a = *savekidx@0x00af        ; CTRL.S:277
  *CharX@0x0041 = a            ; CTRL.S:278
  tail_call rereadblocks                ; CTRL.S:279
:ok:
  call getdist                  ; CTRL.S:284
  call addcharx                  ; CTRL.S:286
  *CharX@0x0041 = a            ; CTRL.S:287
  x = *CharBlockY@0x0045        ; CTRL.S:289
  ??? inx             ; CTRL.S:290
  a = *(FloorY@0x127e + x)   ; CTRL.S:291
  *CharY@0x0042 = a            ; CTRL.S:292
  a = #0x00                  ; CTRL.S:294
  *CharYVel@0x0048 = a            ; CTRL.S:295
  a = #0x0f                  ; CTRL.S:297
  call jumpseq                  ; CTRL.S:298
  call animchar                  ; CTRL.S:299
  a = #0x0c                  ; CTRL.S:301
  *stunned@0x00e6 = a            ; CTRL.S:302
]rts:
  return                           ; CTRL.S:303
:test:
  call getabove                  ; CTRL.S:305
  *blockid@0x008b = a            ; CTRL.S:306
  call getaboveinf                  ; CTRL.S:307
  tail_call checkledge                ; CTRL.S:308
}

fn InsideBlock {
  call getdist                  ; CTRL.S:466
  cmp a, #0x08              ; CTRL.S:467
  if a >= #0x08 goto :bumpback  ; CTRL.S:468
:bumpfwd:
  call getinfront                  ; CTRL.S:471
  cmp a, #0x14              ; CTRL.S:472
  if a == #0x14 goto :bumpback  ; CTRL.S:473
  call getdist                  ; CTRL.S:475
  c = 0                            ; CTRL.S:476
  a = a + #0x04 + c              ; CTRL.S:477
:reland:
  call addcharx                  ; CTRL.S:479
  *CharX@0x0041 = a            ; CTRL.S:480
  call rereadblocks                  ; CTRL.S:481
  tail_call getunderft                ; CTRL.S:482
:bumpback:
  call getbehind                  ; CTRL.S:485
  cmp a, #0x14              ; CTRL.S:486
  if a != #0x14 goto :1  ; CTRL.S:487
  call getdist                  ; CTRL.S:490
  c = 0                            ; CTRL.S:491
  a = a + #0x0e + c              ; CTRL.S:492
  ??? eor #$ff            ; CTRL.S:493
  c = 0                            ; CTRL.S:494
  a = a + #0x08 + c              ; CTRL.S:495
  goto :reland                ; CTRL.S:496
:1:
  call getdist                  ; CTRL.S:498
  ??? eor #$ff            ; CTRL.S:499
  c = 0                            ; CTRL.S:500
  a = a + #0x08 + c              ; CTRL.S:501
  goto :reland                ; CTRL.S:502
}

