; module CTRL from 01 POP Source/Source/CTRL.S

fn CHECKFLOOR {
  a = *CharAction@0x0046        ; CTRL.S:107
  if a == #0x06 goto ]rts  ; CTRL.S:109
  if a != #0x05 goto :2  ; CTRL.S:112
  a = *CharPosn@0x0040        ; CTRL.S:113
  if a == #0x6d goto :ong  ; CTRL.S:115
  if a != #0xb9 goto ]rts  ; CTRL.S:117
:ong:
  tail_call onground                ; CTRL.S:118
:2:
  if a == #0x04 goto falling  ; CTRL.S:121
  if a != #0x03 goto :1  ; CTRL.S:123
  a = *CharPosn@0x0040        ; CTRL.S:124
  if a < #0x66 goto ]rts  ; CTRL.S:126
  if a >= #0x6a goto ]rts  ; CTRL.S:128
  tail_call fallon                ; CTRL.S:129
:1:
  if a == #0x02 goto ]rts  ; CTRL.S:132
  tail_call onground                ; CTRL.S:133
]rts:
  return                           ; CTRL.S:99
}

fn onground {
  a = *Fcheck@0x0085        ; CTRL.S:314
  ??? and #fcheckmark            ; CTRL.S:315
  if eq goto ]rts       ; CTRL.S:316
  call getunderft                  ; CTRL.S:318
  cmp a, #0x14              ; CTRL.S:319
  if a != #0x14 goto :1  ; CTRL.S:320
  call InsideBlock                  ; CTRL.S:321
:1:
  call cmpspace                  ; CTRL.S:323
  if ne goto ]rts       ; CTRL.S:324
  a = *level@0x03f4        ; CTRL.S:328
