  if a != #0x0c goto :no  ; CTRL.S:330
  a = *mergetimer@0x00df        ; CTRL.S:331
  if a >=0 goto :no  ; CTRL.S:332
  a = *CharBlockY@0x0045        ; CTRL.S:333
